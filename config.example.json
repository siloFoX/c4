{
  "daemon": {
    "port": 3456,
    "host": "127.0.0.1",
    "idleThresholdMs": 3000
  },

  "pty": {
    "cols": 160,
    "rows": 48,
    "scrollback": 2000,
    "defaultCommand": "claude",
    "defaultShell": "auto"
  },

  "targets": {
    "local": {
      "type": "local",
      "defaultCwd": "",
      "commandMap": {
        "claude": "claude"
      }
    },
    "my-server": {
      "type": "ssh",
      "host": "user@192.168.1.100",
      "defaultCwd": "/home/user/project",
      "commandMap": {
        "claude": "/home/user/.local/bin/claude"
      }
    }
  },

  "compatibility": {
    "testedVersions": ["2.1.85", "2.1.90"],
    "minVersion": "2.1.0",
    "patterns": {
      "trustPrompt": "trust this folder",
      "permissionPrompt": "Do you want to proceed?",
      "fileCreatePrompt": "Do you want to create",
      "fileEditPrompt": "Do you want to make this edit",
      "bashHeader": "Bash command",
      "editHeader": "Edit file",
      "createHeader": "Create file",
      "yesOption": "1. Yes",
      "yesAlwaysEditOption": "Yes, allow all edits during this session",
      "yesAlwaysBashOption": "Yes, and don't ask again for:",
      "noOption": "No",
      "promptFooter": "Esc to cancel"
    }
  },

  "autoApprove": {
    "enabled": false,
    "alwaysApproveForSession": false,
    "autonomyLevel": 0,
    "rules": [
      { "pattern": "Read", "action": "approve" },
      { "pattern": "Glob", "action": "approve" },
      { "pattern": "Grep", "action": "approve" },
      { "pattern": "Bash(ls:*)", "action": "approve" },
      { "pattern": "Bash(find:*)", "action": "approve" },
      { "pattern": "Bash(grep:*)", "action": "approve" },
      { "pattern": "Bash(cat:*)", "action": "approve" },
      { "pattern": "Bash(head:*)", "action": "approve" },
      { "pattern": "Bash(tail:*)", "action": "approve" },
      { "pattern": "Bash(wc:*)", "action": "approve" },
      { "pattern": "Bash(echo:*)", "action": "approve" },
      { "pattern": "Bash(pwd)", "action": "approve" },
      { "pattern": "Bash(cd:*)", "action": "approve" },
      { "pattern": "Bash(git:*)", "action": "approve" },
      { "pattern": "Bash(python:*)", "action": "ask" },
      { "pattern": "Bash(node:*)", "action": "ask" },
      { "pattern": "Bash(npm:*)", "action": "ask" },
      { "pattern": "Bash(curl:*)", "action": "ask" },
      { "pattern": "Write", "action": "ask" },
      { "pattern": "Edit", "action": "ask" },
      { "pattern": "Bash(rm:*)", "action": "deny" },
      { "pattern": "Bash(sudo:*)", "action": "deny" },
      { "pattern": "Bash(kill:*)", "action": "deny" },
      { "pattern": "Bash(reboot:*)", "action": "deny" },
      { "pattern": "Bash(shutdown:*)", "action": "deny" },
      { "pattern": "Bash(chmod:*)", "action": "deny" },
      { "pattern": "Bash(chown:*)", "action": "deny" }
    ],
    "defaultAction": "ask"
  },

  "worktree": {
    "enabled": true,
    "projectRoot": ""
  },

  "maxWorkers": 5,

  "healthCheck": {
    "enabled": true,
    "intervalMs": 30000,
    "timeoutMs": 600000,
    "autoRestart": false
  },

  "effort": {
    "dynamic": true,
    "thresholds": {
      "high": 100,
      "max": 500
    },
    "default": "high"
  },

  "workerDefaults": {
    "trustFolder": true,
    "effortLevel": "max",
    "effortSetup": {
      "retries": 3,
      "phaseTimeoutMs": 8000,
      "inputDelayMs": 500,
      "confirmDelayMs": 500
    },
    "model": "default"
  },

  "logs": {
    "rawLog": true,
    "maxLogSizeMb": 50,
    "cleanupAfterMinutes": 60
  },

  "scope": {
    "defaultScope": {},
    "presets": {
      "backend": {
        "description": "Backend files only",
        "allowFiles": ["src/**", "tests/**", "config.*"],
        "denyFiles": [],
        "allowBash": ["grep", "find", "cat", "head", "tail", "python", "node", "npm", "git"],
        "denyBash": ["pip", "docker", "rm", "sudo"]
      },
      "frontend": {
        "description": "Frontend files only",
        "allowFiles": ["src/components/**", "src/pages/**", "public/**", "tests/**"],
        "denyFiles": ["src/server/**", "src/db/**"],
        "allowBash": ["grep", "find", "cat", "npm", "git"],
        "denyBash": ["pip", "docker", "rm", "sudo"]
      },
      "docs-only": {
        "description": "Documentation only",
        "allowFiles": ["*.md", "docs/**"],
        "denyFiles": [],
        "allowBash": ["grep", "find", "cat", "git"],
        "denyBash": ["pip", "npm", "docker", "rm", "sudo", "node", "python"]
      }
    }
  },

  "rules": {
    "appendToTask": true,
    "summary": ""
  },

  "scribe": {
    "enabled": false,
    "intervalMs": 300000,
    "outputPath": "docs/session-context.md",
    "projectId": "",
    "maxEntries": 200
  },

  "ssh": {
    "controlMaster": true,
    "controlPersist": 60,
    "serverAliveInterval": 15,
    "serverAliveCountMax": 3,
    "reconnect": true,
    "maxReconnects": 3,
    "reconnectDelayMs": 5000
  },

  "tokenMonitor": {
    "enabled": true,
    "dailyLimit": 0,
    "warnThreshold": 0.8,
    "projectId": ""
  },

  "pool": {
    "enabled": false,
    "maxIdleMs": 300000
  },

  "autoMode": {
    "enabled": false,
    "allowOverride": true
  },

  "managerRotation": {
    "compactThreshold": 0,
    "enabled": false
  },

  "templates": {
    "planner": {
      "description": "Planner — 설계 전담, Opus 모델",
      "model": "opus",
      "effort": "max",
      "profile": "planner",
      "promptPrefix": "[역할: Planner] 설계와 분석에 집중. 코드 수정보다 계획/구조 설계."
    },
    "executor": {
      "description": "Executor — 구현 전담, Sonnet 모델",
      "model": "sonnet",
      "effort": "high",
      "profile": "executor",
      "promptPrefix": "[역할: Executor] 구현에 집중. 설계대로 코드 작성/테스트."
    },
    "reviewer": {
      "description": "Reviewer — 리뷰 전담, Haiku 모델",
      "model": "haiku",
      "effort": "high",
      "profile": "reviewer",
      "promptPrefix": "[역할: Reviewer] 코드 리뷰 집중. 수정 금지, 리뷰 코멘트만."
    }
  },

  "swarm": {
    "enabled": false,
    "maxSubagents": 10,
    "trackUsage": true
  },

  "hooks": {
    "enabled": true,
    "injectToWorkers": true
  },

  "profiles": {
    "default": {
      "permissions": {
        "allow": [
          "Bash(c4:*)", "Bash(git:*)", "Bash(grep:*)", "Bash(find:*)",
          "Bash(cat:*)", "Bash(ls:*)", "Bash(head:*)", "Bash(tail:*)"
        ],
        "deny": ["Bash(rm:*)", "Bash(sudo:*)"]
      }
    },
    "executor": {
      "permissions": {
        "allow": [
          "Bash(c4:*)", "Bash(git:*)", "Bash(npm:*)", "Bash(node:*)",
          "Bash(grep:*)", "Bash(find:*)", "Bash(cat:*)", "Bash(ls:*)",
          "Edit", "Write"
        ],
        "deny": ["Bash(rm:*)", "Bash(sudo:*)", "Bash(docker:*)"]
      }
    },
    "reviewer": {
      "permissions": {
        "allow": [
          "Bash(c4:*)", "Bash(git:*)", "Bash(grep:*)", "Bash(find:*)",
          "Bash(cat:*)", "Bash(ls:*)", "Bash(npm:*)"
        ],
        "deny": ["Edit", "Write", "Bash(rm:*)", "Bash(sudo:*)"]
      }
    },
    "planner": {
      "permissions": {
        "allow": [
          "Bash(c4:*)", "Bash(git:*)", "Bash(grep:*)", "Bash(find:*)",
          "Bash(cat:*)", "Bash(ls:*)"
        ],
        "deny": ["Bash(rm:*)", "Bash(sudo:*)", "Bash(npm:*)"]
      }
    },
    "node": {
      "permissions": {
        "allow": ["Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)"]
      }
    },
    "python": {
      "permissions": {
        "allow": ["Bash(python:*)", "Bash(pip:*)", "Bash(conda:*)"]
      }
    },
    "rust": {
      "permissions": {
        "allow": ["Bash(cargo:*)", "Bash(rustc:*)"]
      }
    },
    "web": {
      "description": "Web development project preset",
      "permissions": {
        "allow": [
          "Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)",
          "Bash(yarn:*)", "Bash(pnpm:*)", "Bash(bun:*)",
          "Bash(tsc:*)", "Bash(eslint:*)", "Bash(prettier:*)",
          "Edit", "Write"
        ],
        "deny": ["Bash(rm:*)", "Bash(sudo:*)", "Bash(docker:*)"]
      }
    },
    "ml": {
      "description": "ML/Data Science project preset",
      "permissions": {
        "allow": [
          "Bash(python:*)", "Bash(python3:*)", "Bash(pip:*)", "Bash(pip3:*)",
          "Bash(conda:*)", "Bash(jupyter:*)", "Bash(ipython:*)",
          "Bash(nvidia-smi:*)", "Bash(torchrun:*)",
          "Edit", "Write"
        ],
        "deny": ["Bash(rm:*)", "Bash(sudo:*)", "Bash(shutdown:*)", "Bash(reboot:*)"]
      }
    },
    "infra": {
      "description": "Infrastructure/DevOps project preset",
      "permissions": {
        "allow": [
          "Bash(docker:*)", "Bash(docker-compose:*)",
          "Bash(terraform:*)", "Bash(ansible:*)",
          "Bash(kubectl:*)", "Bash(helm:*)",
          "Bash(ssh:*)", "Bash(scp:*)",
          "Edit", "Write"
        ],
        "deny": ["Bash(rm -rf:*)", "Bash(sudo:*)", "Bash(shutdown:*)", "Bash(reboot:*)"]
      }
    }
  },

  "ci": {
    "enabled": true,
    "testCommand": "npm test",
    "timeoutMs": 120000
  },

  "intervention": {
    "enabled": true,
    "questionPatterns": [],
    "escalation": {
      "maxRetries": 3
    },
    "routineCheck": true
  },

  "notifications": {
    "language": "ko",
    "slack": {
      "enabled": false,
      "webhookUrl": "",
      "intervalMs": 300000,
      "alertOnly": false
    },
    "discord": {
      "enabled": false,
      "webhookUrl": ""
    },
    "telegram": {
      "enabled": false,
      "botToken": "",
      "chatId": ""
    },
    "kakaowork": {
      "enabled": false,
      "webhookUrl": ""
    },
    "email": {
      "enabled": false,
      "from": "",
      "to": "",
      "smtp": {
        "host": "smtp.gmail.com",
        "port": 587,
        "secure": false,
        "auth": {
          "user": "",
          "pass": ""
        }
      }
    }
  },

  "gitBash": {
    "disablePathConversion": true
  }
}

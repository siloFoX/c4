{
  "daemon": {
    "port": 3456,
    "host": "127.0.0.1",
    "idleThresholdMs": 3000
  },

  "pty": {
    "cols": 160,
    "rows": 48,
    "scrollback": 2000,
    "defaultCommand": "claude",
    "defaultShell": "auto"
  },

  "targets": {
    "local": {
      "type": "local",
      "defaultCwd": "",
      "commandMap": {
        "claude": "claude"
      }
    },
    "my-server": {
      "type": "ssh",
      "host": "user@192.168.1.100",
      "defaultCwd": "/home/user/project",
      "commandMap": {
        "claude": "/home/user/.local/bin/claude"
      }
    }
  },

  "compatibility": {
    "testedVersions": ["2.1.85", "2.1.90"],
    "minVersion": "2.1.0",
    "patterns": {
      "trustPrompt": "trust this folder",
      "permissionPrompt": "Do you want to proceed?",
      "fileCreatePrompt": "Do you want to create",
      "fileEditPrompt": "Do you want to make this edit",
      "bashHeader": "Bash command",
      "editHeader": "Edit file",
      "createHeader": "Create file",
      "yesOption": "1. Yes",
      "yesAlwaysEditOption": "Yes, allow all edits during this session",
      "yesAlwaysBashOption": "Yes, and don't ask again for:",
      "noOption": "No",
      "promptFooter": "Esc to cancel"
    }
  },

  "autoApprove": {
    "enabled": false,
    "alwaysApproveForSession": false,
    "rules": [
      { "pattern": "Read", "action": "approve" },
      { "pattern": "Glob", "action": "approve" },
      { "pattern": "Grep", "action": "approve" },
      { "pattern": "Bash(ls:*)", "action": "approve" },
      { "pattern": "Bash(find:*)", "action": "approve" },
      { "pattern": "Bash(grep:*)", "action": "approve" },
      { "pattern": "Bash(cat:*)", "action": "approve" },
      { "pattern": "Bash(head:*)", "action": "approve" },
      { "pattern": "Bash(tail:*)", "action": "approve" },
      { "pattern": "Bash(wc:*)", "action": "approve" },
      { "pattern": "Bash(echo:*)", "action": "approve" },
      { "pattern": "Bash(pwd)", "action": "approve" },
      { "pattern": "Bash(cd:*)", "action": "approve" },
      { "pattern": "Bash(git:*)", "action": "approve" },
      { "pattern": "Bash(python:*)", "action": "ask" },
      { "pattern": "Bash(node:*)", "action": "ask" },
      { "pattern": "Bash(npm:*)", "action": "ask" },
      { "pattern": "Bash(curl:*)", "action": "ask" },
      { "pattern": "Write", "action": "ask" },
      { "pattern": "Edit", "action": "ask" },
      { "pattern": "Bash(rm:*)", "action": "deny" },
      { "pattern": "Bash(sudo:*)", "action": "deny" },
      { "pattern": "Bash(kill:*)", "action": "deny" },
      { "pattern": "Bash(reboot:*)", "action": "deny" },
      { "pattern": "Bash(shutdown:*)", "action": "deny" },
      { "pattern": "Bash(chmod:*)", "action": "deny" },
      { "pattern": "Bash(chown:*)", "action": "deny" }
    ],
    "defaultAction": "ask"
  },

  "worktree": {
    "enabled": true,
    "projectRoot": ""
  },

  "maxWorkers": 5,

  "healthCheck": {
    "enabled": true,
    "intervalMs": 30000,
    "timeoutMs": 600000,
    "autoRestart": false
  },

  "effort": {
    "dynamic": true,
    "thresholds": {
      "high": 100,
      "max": 500
    },
    "default": "high"
  },

  "workerDefaults": {
    "trustFolder": true,
    "effortLevel": "max",
    "effortSetup": {
      "retries": 3,
      "phaseTimeoutMs": 8000,
      "inputDelayMs": 500,
      "confirmDelayMs": 500
    },
    "model": "default"
  },

  "logs": {
    "rawLog": true,
    "maxLogSizeMb": 50,
    "cleanupAfterMinutes": 60
  },

  "scope": {
    "defaultScope": {},
    "presets": {
      "backend": {
        "description": "Backend files only",
        "allowFiles": ["src/**", "tests/**", "config.*"],
        "denyFiles": [],
        "allowBash": ["grep", "find", "cat", "head", "tail", "python", "node", "npm", "git"],
        "denyBash": ["pip", "docker", "rm", "sudo"]
      },
      "frontend": {
        "description": "Frontend files only",
        "allowFiles": ["src/components/**", "src/pages/**", "public/**", "tests/**"],
        "denyFiles": ["src/server/**", "src/db/**"],
        "allowBash": ["grep", "find", "cat", "npm", "git"],
        "denyBash": ["pip", "docker", "rm", "sudo"]
      },
      "docs-only": {
        "description": "Documentation only",
        "allowFiles": ["*.md", "docs/**"],
        "denyFiles": [],
        "allowBash": ["grep", "find", "cat", "git"],
        "denyBash": ["pip", "npm", "docker", "rm", "sudo", "node", "python"]
      }
    }
  },

  "rules": {
    "appendToTask": true,
    "summary": ""
  },

  "scribe": {
    "enabled": false,
    "intervalMs": 300000,
    "outputPath": "docs/session-context.md",
    "projectId": "",
    "maxEntries": 200
  },

  "ssh": {
    "controlMaster": true,
    "controlPersist": 60,
    "serverAliveInterval": 15,
    "serverAliveCountMax": 3,
    "reconnect": true,
    "maxReconnects": 3,
    "reconnectDelayMs": 5000
  },

  "tokenMonitor": {
    "enabled": true,
    "dailyLimit": 0,
    "warnThreshold": 0.8,
    "projectId": ""
  },

  "pool": {
    "enabled": false,
    "maxIdleMs": 300000
  },

  "hooks": {
    "enabled": true,
    "injectToWorkers": true
  },

  "gitBash": {
    "disablePathConversion": true
  }
}

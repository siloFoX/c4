{
  "name": "c4-cli",
  "version": "1.10.675",
  "description": "Claude {Claude Code} Code — An agent-on-agent orchestrator that lets Claude manage multiple Claude Code instances via virtual terminals",
  "main": "src/daemon.js",
  "bin": {
    "c4": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/daemon.js",
    "daemon": "node src/daemon.js",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "test": "node tests/run-all.js",
    "test:browser": "node --test tests/web-smoke.test.js",
    "test:docker": "node --test tests/risk-shadow-exec-docker.test.js",
    "lint:openapi": "node scripts/validate-openapi.js",
    "lint:schema-drift": "node scripts/check-schema-drift.js --strict",
    "lint:runtime-drift": "node scripts/check-runtime-drift.js",
    "lint:bundle-size": "node scripts/check-bundle-size.js",
    "lint:i18n-lockstep": "node scripts/check-i18n-lockstep.js",
    "lint:i18n-visual": "node scripts/i18n-visual-check.js",
    "lint:a11y": "node scripts/a11y-audit.js",
    "lint:console": "node scripts/console-error-audit.js",
    "snapshot:diff": "node scripts/visual-snapshot-diff.js",
    "snapshot:update": "node scripts/snapshot-update.js",
    "lint": "npm run lint:openapi && npm run lint:schema-drift && npm run lint:i18n-lockstep",
    "check": "npm run lint && npm test && npm --prefix web run build && npm run lint:bundle-size",
    "check:full": "sh scripts/check-full.sh",
    "prepublishOnly": "npm run build:web && node tests/run-all.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "orchestrator",
    "agent-orchestrator",
    "multi-agent",
    "multi-agent-system",
    "autonomous-coding",
    "recursive-agents",
    "ai-coding-agent",
    "pty",
    "terminal",
    "ai",
    "automation",
    "cli",
    "devtools",
    "worker-management",
    "task-queue",
    "git-worktree"
  ],
  "author": "siloFoX",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/siloFoX/c4.git"
  },
  "homepage": "https://github.com/siloFoX/c4#readme",
  "bugs": {
    "url": "https://github.com/siloFoX/c4/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "linux",
    "darwin"
  ],
  "files": [
    "src/",
    "web/dist/",
    "config.json",
    "config.example.json",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.4",
    "redoc": "^2.5.2",
    "swagger-ui-dist": "^5.32.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}

{
  "name": "c4-sdk",
  "version": "0.2.0",
  "description": "Programmatic control SDK for the C4 (Claude Code Code) daemon HTTP API",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./typed": {
      "types": "./dist/c4-client.d.ts",
      "import": "./dist/c4-client.js",
      "require": "./dist/c4-client.cjs",
      "default": "./dist/c4-client.js"
    },
    "./typed-source": {
      "types": "./c4-client.ts",
      "default": "./c4-client.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && node scripts/wrap-cjs.js",
    "regen": "node ../src/cli.js openapi --sdk > c4-client.ts",
    "prepublishOnly": "npm run regen && npm run build"
  },
  "license": "MIT",
  "author": "siloFoX",
  "repository": {
    "type": "git",
    "url": "https://github.com/siloFoX/c4.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/siloFoX/c4#readme",
  "bugs": {
    "url": "https://github.com/siloFoX/c4/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "lib/",
    "dist/",
    "examples/",
    "c4-client.ts",
    "tsconfig.json",
    "README.md"
  ],
  "keywords": [
    "c4",
    "claude",
    "claude-code",
    "agent",
    "sdk",
    "orchestrator",
    "multi-agent",
    "daemon",
    "openapi",
    "typescript"
  ],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}

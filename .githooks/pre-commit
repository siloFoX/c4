#!/bin/sh
# C4 pre-commit hook: protect main branch from direct commits.
# Commits are only allowed on c4/ prefixed branches (or non-main branches).
# Install: git config core.hooksPath .githooks (done by c4 init)

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ "$branch" = "main" ]; then
  # Allow merge commits (git merge creates MERGE_HEAD)
  if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    exit 0
  fi
  echo ""
  echo "  [c4] Direct commits to main are blocked."
  echo "  Use a c4/ branch and merge with: c4 merge <branch>"
  echo ""
  exit 1
fi

# --- Rule enforcement: warn on compound commands in staged diffs ---
# Detects &&, |, ; in bash/shell command contexts within code changes.
# This is a warning only (does not block commit).

compound_lines=$(git diff --cached --diff-filter=ACM -U0 -- '*.js' '*.sh' '*.md' 2>/dev/null \
  | grep '^+' | grep -v '^+++' \
  | grep -E '(&&|\|[^|]|;)\s' \
  | grep -iv '(\/\/|#|<!--).*(&&|\||;)' \
  || true)

if [ -n "$compound_lines" ]; then
  echo ""
  echo "  [c4] WARNING: Compound commands detected in staged changes."
  echo "  CLAUDE.md rule: Use single commands instead of &&, |, ;"
  echo ""
  echo "  Matches:"
  echo "$compound_lines" | head -10 | sed 's/^/    /'
  echo ""
  echo "  Consider splitting into separate commands."
  echo "  (This is a warning — commit proceeds.)"
  echo ""
fi

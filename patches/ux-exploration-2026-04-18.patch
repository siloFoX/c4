From 4aa808b0a5e9b5ec830bfae1306547742185f727 Mon Sep 17 00:00:00 2001
From: c4-worker <c4-worker@c4.local>
Date: Sat, 18 Apr 2026 17:32:56 +0000
Subject: [PATCH 3/6] fix(auth): keep /auth/status open and fail safe in the
 Web UI

Two related defects surfaced by the UX exploration runner:

1. /auth/status was protected by the JWT middleware. /api/auth/status
   therefore returned 401 to anonymous clients, which is the very
   request the React app makes to decide whether to render the login
   page in the first place. Add it to OPEN_API_ROUTES so unauthed
   browsers can still ask "is auth on?".

2. fetchAuthStatus() previously translated any non-OK response (or any
   thrown error) into { enabled: false }. App.tsx then set authState
   to 'disabled' and fell through to the dashboard render branch -
   meaning a misconfigured proxy, a daemon restart, or any transient
   network blip silently rendered the operator UI to anonymous users.
   Default to { enabled: true } on error so the worst case is showing
   the login screen instead of the dashboard.

Together they remove a UI-level fail-open: even with a bad
/auth/status response the user is now stopped at the sign-in card.
---
 src/auth.js        | 6 +++++-
 web/src/lib/api.ts | 8 ++++++--
 2 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/src/auth.js b/src/auth.js
index 2bf775f..7607790 100644
--- a/src/auth.js
+++ b/src/auth.js
@@ -22,9 +22,13 @@ const DEFAULT_BCRYPT_ROUNDS = 10;
 
 // Routes the middleware must let through even when auth is enabled.
 // The login endpoint is needed to obtain a token in the first place,
-// and the health check stays public for daemon probes.
+// the health check stays public for daemon probes, and /auth/status is
+// the very first call the Web UI makes to decide whether to render the
+// login page - if it returns 401 unauthed clients get stuck in a
+// chicken-and-egg loop and the React app falls open to the dashboard.
 const OPEN_API_ROUTES = new Set([
   '/auth/login',
+  '/auth/status',
   '/health',
 ]);
 
diff --git a/web/src/lib/api.ts b/web/src/lib/api.ts
index 7293184..742414e 100644
--- a/web/src/lib/api.ts
+++ b/web/src/lib/api.ts
@@ -112,12 +112,16 @@ export interface AuthStatus {
 }
 
 export async function fetchAuthStatus(): Promise<AuthStatus> {
+  // Fail safe: if the status check itself errors or returns non-OK we
+  // assume auth is enabled. Treating an error as "auth disabled" would
+  // silently render the dashboard for unauthenticated users when the
+  // daemon is mid-restart or behind a misconfigured proxy.
   try {
     const res = await fetch('/api/auth/status');
-    if (!res.ok) return { enabled: false };
+    if (!res.ok) return { enabled: true };
     const data = (await res.json()) as AuthStatus;
     return { enabled: Boolean(data.enabled) };
   } catch {
-    return { enabled: false };

From d04533aaf4ace584fb937f5732b698d83d64f00e Mon Sep 17 00:00:00 2001
From: c4-worker <c4-worker@c4.local>
Date: Sat, 18 Apr 2026 17:12:26 +0000
Subject: [PATCH 2/6] fix(web): stop stripping /api in vite proxy so auth check
 runs

The daemon's session-auth middleware only runs the JWT check when the
incoming path keeps its /api prefix (resolveApiRoute returns
isApi=true). Vite's rewrite previously stripped the prefix, so every
proxied request reached the daemon as /<route>, the auth check was
skipped, and authCheck.decoded stayed undefined. The route-level
RBAC gate (requireRole) then 401'd with "Authentication required"
even when the browser sent a valid Bearer token, breaking
/api/workflows and any other RBAC-gated GET in dev.

Forwarding /api/* unchanged lets the daemon decode the token in the
middleware as it already does in production (where the built UI hits
the daemon directly on :3456).
---
 web/vite.config.ts | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/web/vite.config.ts b/web/vite.config.ts
index 6dd7d11..057fa91 100644
--- a/web/vite.config.ts
+++ b/web/vite.config.ts
@@ -7,10 +7,13 @@ export default defineConfig({
     host: '0.0.0.0',
     port: 5173,
     proxy: {
+      // Forward /api/* unchanged so the daemon's resolveApiRoute() still
+      // sees the /api prefix. The auth middleware only runs the JWT check
+      // when isApiPrefixed is true; stripping /api here would skip it and
+      // make every authed route 401 even with a valid token.
       '/api': {
         target: 'http://localhost:3456',
         changeOrigin: true,
-        rewrite: (path) => path.replace(/^\/api/, ''),
       },
     },
   },
-- 

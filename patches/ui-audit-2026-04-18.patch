new file mode 100644
index 0000000..00363c4
--- /dev/null
+++ b/scripts/ui-audit-login.js
@@ -0,0 +1,46 @@
+#!/usr/bin/env node
+// Login helper for ui-audit.
+//
+// Reads the silofox password from a credential file (default
+// /tmp/c4-silofox-cred; override with C4_CRED_FILE), exchanges it for a JWT
+// against /api/auth/login, and writes the token to /tmp/c4-audit-token.json
+// (override with C4_AUDIT_TOKEN_FILE).
+//
+// The password never appears on argv or in process-level env written by this
+// script. Downstream audit scripts read the token from the JSON file.
+
+const fs = require('fs');
+
+const CRED_FILE = process.env.C4_CRED_FILE || '/tmp/c4-silofox-cred';
+const TOKEN_FILE = process.env.C4_AUDIT_TOKEN_FILE || '/tmp/c4-audit-token.json';
+const BASE_URL = process.env.C4_AUDIT_BASE_URL || 'http://localhost:5173';
+const USER = process.env.C4_AUDIT_USER || 'silofox';
+
+async function main() {
+  if (!fs.existsSync(CRED_FILE)) {
+    throw new Error(`credential file not found: ${CRED_FILE}`);
+  }
+  const password = fs.readFileSync(CRED_FILE, 'utf8').replace(/[\r\n]+$/, '');
+  if (!password) throw new Error(`credential file empty: ${CRED_FILE}`);
+
+  const res = await fetch(`${BASE_URL}/api/auth/login`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ user: USER, password }),
+  });
+  const data = await res.json().catch(() => ({}));
+  if (!res.ok || !data.token) {
+    throw new Error(`login failed: HTTP ${res.status} ${JSON.stringify(data)}`);
+  }
+  fs.writeFileSync(
+    TOKEN_FILE,
+    JSON.stringify({ token: data.token, user: data.user, baseUrl: BASE_URL, obtainedAt: new Date().toISOString() }, null, 2),
+    { mode: 0o600 }
+  );
+  console.log(`token saved -> ${TOKEN_FILE} (user=${data.user})`);
+}
+
+main().catch((err) => {
+  console.error(`[ui-audit-login] ${err.message}`);
+  process.exit(1);
+});

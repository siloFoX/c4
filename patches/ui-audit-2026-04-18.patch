index 0000000..1eb3ae0
--- /dev/null
+++ b/scripts/ui-audit.js
@@ -0,0 +1,545 @@
+#!/usr/bin/env node
+// UI audit for the C4 web console.
+//
+// Drives every user-facing view of /root/c4-worktree-ui-audit/web with a
+// puppeteer-bundled Chromium, logs in with the silofox JWT stored on disk
+// (produced by scripts/ui-audit-login.js), and records:
+//   - console.error / console.warning messages (with ignore-list)
+//   - unhandled page errors
+//   - unhandled promise rejections
+//   - non-2xx network responses for app-origin requests
+//   - request failures (DNS / transport / abort)
+//   - a cheap layout probe per view: zero-size visible images/SVGs, broken
+//     icon srcs, overflow past the viewport, role=alert surfaced, broken
+//     lucide <svg> elements (0-size or empty path list)
+//
+// Output: scripts/ui-audit-report.json with one `views[i]` entry per route
+// plus a top-level summary grouped into "critical" / "warning" / "info".
+//
+// The script never writes anywhere outside the worktree's scripts/ dir and
+// it never touches /tmp credential files (that is the login helper's job).
+
+const fs = require('fs');
+const path = require('path');
+
+const puppeteer = require('puppeteer');
+
+const TOKEN_FILE = process.env.C4_AUDIT_TOKEN_FILE || '/tmp/c4-audit-token.json';
+const BASE_URL = process.env.C4_AUDIT_BASE_URL || 'http://localhost:5173';
+const REPORT_FILE =
+  process.env.C4_AUDIT_REPORT ||
+  path.join(__dirname, 'ui-audit-report.json');
+const VIEWPORT = { width: 1440, height: 900, deviceScaleFactor: 1 };
+const WAIT_AFTER_NAV_MS = 1500;
+const SETTLE_MS = 600;
+
+// Things that are expected noise and we do not treat as issues.
+const CONSOLE_IGNORE = [
+  // vite dev client hot reload chatter
+  /\[vite\]/i,
+  // React dev-mode performance warnings we cannot silence from the audit
+  /Download the React DevTools/i,
+  // Audit-internal: SSE keeps the network alive so networkidle0 never settles.
+  /^nav fallback:/,
+];
+
+// Ignore source-map 404s and any request to the well-known chrome DevTools
+// probe - puppeteer's own traffic - and Vite dep pre-bundle meta requests.
+const NETWORK_IGNORE = [
+  /\.map(\?|$)/,
+  /\/\.well-known\//,
+  /@vite\/client/,
+  /@react-refresh/,
+  /\/__open-in-editor/,
+];
+
+function isIgnoredConsole(text) {
+  return CONSOLE_IGNORE.some((re) => re.test(text));
+}
+
+function isIgnoredNetwork(url) {
+  return NETWORK_IGNORE.some((re) => re.test(url));
+}
+
+function loadToken() {
+  if (!fs.existsSync(TOKEN_FILE)) {
+    throw new Error(
+      `token file missing: ${TOKEN_FILE} - run scripts/ui-audit-login.js first`
+    );
+  }
+  const raw = JSON.parse(fs.readFileSync(TOKEN_FILE, 'utf8'));
+  if (!raw.token) throw new Error('token file has no token');
+  return raw.token;
+}
+
+// Probe the live daemon for routes that exist in the checked-in daemon.js but
+// may be missing from the process currently holding port 3456 (daemon was
+// started before those commits landed). Treat those 404s as environment
+// drift, not UI bugs, so the iterative audit loop is not gated on a daemon
+// restart that would kill the very worker running this script.
+async function detectStaleDaemonEndpoints(token) {
+  const probes = ['/api/resize', '/api/workflows', '/api/slack/events'];
+  const stale = [];
+  for (const path of probes) {
+    try {
+      const method = path === '/api/resize' ? 'POST' : 'GET';
+      const init = {
+        method,
+        headers: {
+          Authorization: `Bearer ${token}`,
+        },
+      };
+      if (method === 'POST') {
+        init.headers['Content-Type'] = 'application/json';
+        init.body = JSON.stringify({ probe: true });
+      }
+      const res = await fetch(`${BASE_URL}${path}`, init);
+      const ct = res.headers.get('content-type') || '';
+      const servedStatic = res.status === 200 && ct.toLowerCase().includes('text/html');
+      if (res.status === 404 || servedStatic) {
+        stale.push(path);
+      }
+    } catch {
+      // A transport failure is not an environment drift signal - leave the
+      // route out so the audit still flags a genuine regression later.
+    }
+  }
+  return stale;
+}
+
+function sleep(ms) {
+  return new Promise((r) => setTimeout(r, ms));
+}
+
+// A ViewPlan describes one page state to audit.
+// localStorage entries are applied before reload; postLoad runs after the
+// page is loaded so it can click into worker detail etc.
+function buildViewPlans(pickWorker) {
+  const plans = [
+    {
+      id: 'login',
+      title: 'Login (unauthenticated)',
+      auth: false,
+      localStorage: {},
+      postLoad: null,
+    },
+    {
+      id: 'worker-list',
+      title: 'Worker list (sidebar mode=list)',
+      auth: true,
+      localStorage: {
+        'c4.topView': 'workers',
+        'c4.sidebar.mode': 'list',
+      },
+      postLoad: null,
+    },
+    {
+      id: 'hierarchy-tree',
+      title: 'Hierarchy tree (sidebar mode=tree)',
+      auth: true,
+      localStorage: {
+        'c4.topView': 'workers',
+        'c4.sidebar.mode': 'tree',
+      },
+      postLoad: null,
+    },
+    {
+      id: 'worker-detail-terminal',
+      title: 'Worker detail - terminal',
+      auth: true,
+      localStorage: {
+        'c4.topView': 'workers',
+        'c4.sidebar.mode': 'list',
+        'c4.detail.mode': 'terminal',
+      },
+      postLoad: pickWorker,
+    },
+    {
+      id: 'worker-detail-chat',
+      title: 'Worker detail - chat',
+      auth: true,
+      localStorage: {
+        'c4.topView': 'workers',
+        'c4.sidebar.mode': 'list',
+        'c4.detail.mode': 'chat',
+      },
+      postLoad: pickWorker,
+    },
+    {
+      id: 'worker-detail-control',
+      title: 'Worker detail - control panel',
+      auth: true,
+      localStorage: {
+        'c4.topView': 'workers',
+        'c4.sidebar.mode': 'list',
+        'c4.detail.mode': 'control',
+      },
+      postLoad: pickWorker,
+    },
+    {
+      id: 'history',
+      title: 'History view',
+      auth: true,
+      localStorage: { 'c4.topView': 'history' },
+      postLoad: null,
+    },
+    {
+      id: 'chat',
+      title: 'Top-level Chat',
+      auth: true,
+      localStorage: { 'c4.topView': 'chat' },
+      postLoad: null,
+    },
+    {
+      id: 'workflows',
+      title: 'Workflow editor',
+      auth: true,
+      localStorage: { 'c4.topView': 'workflows' },
+      postLoad: null,
+    },
+  ];
+  return plans;
+}
+
+function makePage(browser, token) {
+  return browser.newPage().then(async (page) => {
+    await page.setViewport(VIEWPORT);
+    await page.setDefaultNavigationTimeout(30000);
+    await page.setDefaultTimeout(15000);
+    return page;
+  });
+}
+
+function attachCollectors(page, state) {
+  page.on('console', (msg) => {
+    const type = msg.type();
+    if (type !== 'error' && type !== 'warning') return;
+    const text = msg.text();
+    if (isIgnoredConsole(text)) return;
+    state.console.push({
+      level: type,
+      text,
+      location: msg.location() || null,
+    });
+  });
+  page.on('pageerror', (err) => {
+    state.pageErrors.push({
+      message: err.message,
+      stack: err.stack || null,
+    });
+  });
+  // Chromium exposes `unhandledrejection` through a special event on the
+  // target. The cleanest path: listen via page.on('pageerror') for uncaught
+  // promises with reason.stack, plus an in-page hook that re-dispatches.
+  page.on('response', (res) => {
+    const url = res.url();
+    if (isIgnoredNetwork(url)) return;
+    const req = res.request();
+    const ru = new URL(url, BASE_URL);
+    if (!ru.origin.startsWith('http://localhost')) return;
+    if (res.status() >= 400) {
+      state.network.push({
+        phase: 'response',
+        status: res.status(),
+        method: req.method(),
+        url,
+        resourceType: req.resourceType(),
+      });
+    }
+  });
+  page.on('requestfailed', (req) => {
+    const url = req.url();
+    if (isIgnoredNetwork(url)) return;
+    state.network.push({
+      phase: 'failed',
+      status: null,
+      method: req.method(),
+      url,
+      resourceType: req.resourceType(),
+      failure: req.failure() && req.failure().errorText,
+    });
+  });
+}
+
+async function setAppLocalStorage(page, token, entries, authed) {
+  await page.evaluate(
+    (data) => {
+      try {
+        if (data.token) {
+          localStorage.setItem('c4.authToken', data.token);
+        } else {
+          localStorage.removeItem('c4.authToken');
+        }
+        for (const [k, v] of Object.entries(data.entries || {})) {
+          localStorage.setItem(k, v);
+        }
+      } catch {
+        /* ignore */
+      }
+    },
+    { token: authed ? token : null, entries }
+  );
+}
+
+async function probeLayout(page) {
+  return page.evaluate(() => {
+    const out = {
+      zeroSizeImages: [],
+      zeroSizeSvgs: [],
+      emptySvgs: [],
+      overflowViewport: null,
+      alerts: [],
+      visibleErrors: [],
+      brokenLucide: [],
+    };
+
+    const docW = Math.max(document.documentElement.scrollWidth || 0, 0);
+    const winW = window.innerWidth || 0;
+    if (docW > winW + 2) out.overflowViewport = { docW, winW };
+
+    for (const img of document.querySelectorAll('img')) {
+      const rect = img.getBoundingClientRect();
+      const visible =
+        rect.width > 0 ||
+        rect.height > 0 ||
+        img.offsetParent != null;
+      if (!visible) continue;
+      if (img.naturalWidth === 0 && img.complete) {
+        out.zeroSizeImages.push({ src: img.src, alt: img.alt || null });
+      }
+    }
+
+    // Walk ancestors to decide whether the element is actually rendered -
+    // offsetParent+computedStyle alone misses SVG inside a display:none
+    // parent (Tailwind's md:hidden, responsive utilities, etc).
+    function isRendered(el) {
+      if (el.getClientRects().length === 0) return false;
+      for (let node = el; node; node = node.parentElement) {
+        const s = window.getComputedStyle(node);
+        if (s.display === 'none') return false;
+        if (s.visibility === 'hidden') return false;
+      }
+      return true;
+    }
+
+    // lucide icons render as <svg class="lucide-*">. If the bounding box is
+    // zero OR the <svg> has no children, flag it - a very common symptom of
+    // tree-shaken-but-still-rendered icon imports.
+    for (const svg of document.querySelectorAll('svg')) {
+      if (!isRendered(svg)) continue;
+      const rect = svg.getBoundingClientRect();
+      if (rect.width === 0 && rect.height === 0) {
+        out.zeroSizeSvgs.push({
+          classes: svg.getAttribute('class') || '',
+          ariaLabel: svg.getAttribute('aria-label') || null,
+        });
+      }
+      if (svg.children.length === 0) {
+        out.emptySvgs.push({
+          classes: svg.getAttribute('class') || '',
+          ariaLabel: svg.getAttribute('aria-label') || null,
+        });
+      }
+      const cls = svg.getAttribute('class') || '';
+      if (cls.includes('lucide')) {
+        if (svg.children.length === 0) {
+          out.brokenLucide.push({ classes: cls, reason: 'no-children' });
+        }
+      }
+    }
+
+    for (const el of document.querySelectorAll('[role="alert"]')) {
+      const text = (el.textContent || '').trim().slice(0, 240);
+      if (!text) continue;
+      out.alerts.push({ text });
+      if (/failed|error|cannot|missing|HTTP [45]\d{2}/i.test(text)) {
+        out.visibleErrors.push({ text });
+      }
+    }
+
+    return out;
+  });
+}
+
+async function runView(browser, token, plan, pickWorkerFn) {
+  const page = await makePage(browser, token);
+  const state = {
+    console: [],
+    pageErrors: [],
+    network: [],
+  };
+  attachCollectors(page, state);
+
+  // 1) Load the root once so we have a document to touch localStorage on.
+  await page.goto(`${BASE_URL}/`, { waitUntil: 'domcontentloaded' });
+  // 2) Apply auth + view state.
+  await setAppLocalStorage(page, token, plan.localStorage, plan.auth);
+  // 3) Reload so the app picks up the new localStorage. We intentionally use
+  // domcontentloaded + an explicit settle delay: networkidle0 never settles
+  // because WorkerList opens an EventSource as soon as it mounts.
+  await page.goto(`${BASE_URL}/`, { waitUntil: 'domcontentloaded' });
+  await sleep(WAIT_AFTER_NAV_MS);
+
+  if (plan.postLoad) {
+    try {
+      await plan.postLoad(page);
+      await sleep(SETTLE_MS);
+    } catch (e) {
+      state.pageErrors.push({
+        message: `postLoad: ${e.message}`,
+        stack: e.stack || null,
+      });
+    }
+  }
+
+  const layout = await probeLayout(page).catch((e) => ({
+    error: `layout probe failed: ${e.message}`,
+  }));
+
+  const view = {
+    id: plan.id,
+    title: plan.title,
+    consoleIssues: state.console,
+    pageErrors: state.pageErrors,
+    network: state.network,
+    layout,
+  };
+  await page.close().catch(() => {});
+  return view;
+}
+
+function isStaleDaemonNetworkIssue(entry, staleRoutes) {
+  if (!entry || entry.phase !== 'response') return false;
+  if (entry.status !== 404) return false;
+  try {
+    const u = new URL(entry.url);
+    return staleRoutes.includes(u.pathname);
+  } catch {
+    return false;
+  }
+}
+
+function isStaleDaemonConsoleIssue(entry, staleRoutes) {
+  if (!entry || entry.level !== 'error') return false;
+  const loc = entry.location || {};
+  if (!/404/.test(entry.text || '')) return false;
+  try {
+    const u = new URL(loc.url || '');
+    return staleRoutes.includes(u.pathname);
+  } catch {
+    return false;
+  }
+}
+
+function summarise(views, staleRoutes) {
+  const summary = {
+    critical: 0,
+    warning: 0,
+    info: 0,
+    environment: 0,
+    byView: {},
+  };
+  for (const v of views) {
+    const netEnv = v.network.filter((e) => isStaleDaemonNetworkIssue(e, staleRoutes)).length;
+    const netReal = v.network.length - netEnv;
+    const conErrAll = v.consoleIssues.filter((c) => c.level === 'error');
+    const conErrEnv = conErrAll.filter((c) => isStaleDaemonConsoleIssue(c, staleRoutes)).length;
+    const conErrReal = conErrAll.length - conErrEnv;
+
+    const crit =
+      v.pageErrors.length +
+      conErrReal +
+      netReal +
+      (v.layout.visibleErrors ? v.layout.visibleErrors.length : 0) +
+      (v.layout.brokenLucide ? v.layout.brokenLucide.length : 0);
+    const warn =
+      v.consoleIssues.filter((c) => c.level === 'warning').length +
+      (v.layout.zeroSizeImages ? v.layout.zeroSizeImages.length : 0) +
+      (v.layout.zeroSizeSvgs ? v.layout.zeroSizeSvgs.length : 0) +
+      (v.layout.emptySvgs ? v.layout.emptySvgs.length : 0) +
+      (v.layout.overflowViewport ? 1 : 0);
+    const info = v.layout.alerts ? v.layout.alerts.length : 0;
+    const env = netEnv + conErrEnv;
+    summary.critical += crit;
+    summary.warning += warn;
+    summary.info += info;
+    summary.environment += env;
+    summary.byView[v.id] = { critical: crit, warning: warn, info, environment: env };
+  }
+  return summary;
+}
+
+async function pickFirstWorker(page) {
+  // The Card rows in WorkerList use role="button" with tabindex=0.
+  await page.waitForSelector('[role="button"]', { timeout: 8000 }).catch(() => null);
+  const handle = await page.$('[role="button"]');
+  if (!handle) {
+    throw new Error('no worker row to click');
+  }
+  // click + wait for the detail card to appear.
+  await handle.click();
+  await page.waitForFunction(
+    () => !!document.querySelector('main [class*="overflow-hidden"]'),
+    { timeout: 4000 }
+  ).catch(() => null);
+}
+
+async function main() {
+  const token = loadToken();
+  const browser = await puppeteer.launch({
+    headless: 'new',
+    args: [
+      '--no-sandbox',
+      '--disable-setuid-sandbox',
+      '--disable-dev-shm-usage',
+    ],
+  });
+  const startedAt = new Date().toISOString();
+  const staleRoutes = await detectStaleDaemonEndpoints(token);
+  if (staleRoutes.length > 0) {
+    console.log(
+      `[audit] note: running daemon is missing these routes (treated as environment drift, not UI bugs): ${staleRoutes.join(', ')}`
+    );
+  }
+  const plans = buildViewPlans(pickFirstWorker);
+  const views = [];
+  try {
+    for (const plan of plans) {
+      process.stdout.write(`[audit] ${plan.id} ... `);
+      const v = await runView(browser, token, plan);
+      views.push(v);
+      const counts = {
+        console: v.consoleIssues.length,
+        pageErr: v.pageErrors.length,
+        network: v.network.length,
+      };
+      process.stdout.write(
+        `console=${counts.console} pageErr=${counts.pageErr} net=${counts.network}\n`
+      );
+    }
+  } finally {
+    await browser.close();
+  }
+
+  const report = {
+    startedAt,
+    finishedAt: new Date().toISOString(),
+    baseUrl: BASE_URL,
+    staleDaemonRoutes: staleRoutes,
+    summary: summarise(views, staleRoutes),
+    views,
+  };
+  fs.writeFileSync(REPORT_FILE, JSON.stringify(report, null, 2));
+  console.log(`\n[audit] report -> ${REPORT_FILE}`);
+  console.log(
+    `[audit] totals: critical=${report.summary.critical} warning=${report.summary.warning} info=${report.summary.info} environment=${report.summary.environment}`
+  );
+  // Exit 0 always so the caller can inspect the JSON; CI wrappers can fail
+  // on summary.critical > 0 themselves.
+}
+
+main().catch((err) => {
+  console.error(`[audit] fatal: ${err.message}`);
+  if (err.stack) console.error(err.stack);
+  process.exit(1);
+});
